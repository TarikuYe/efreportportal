# ──────────────────────────────────────────────
# Supabase — Project URL & API Keys
# ──────────────────────────────────────────────
# Find these in your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side Supabase client (uses service role — keep secret!)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ──────────────────────────────────────────────
# Authentication & Authorization
# ──────────────────────────────────────────────
# Email address of the Deputy General Manager (sole admin).
# Must be an @efae.com address that is registered via the sign-up flow.
DGM_EMAIL=dgm@efae.com

# ──────────────────────────────────────────────
# Resend (Email Delivery)
# ──────────────────────────────────────────────
# API key from https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# ──────────────────────────────────────────────
# Gmail SMTP Configuration (Optional - for direct email sending)
# ──────────────────────────────────────────────
# Generate app password at: https://myaccount.google.com/apppasswords
# After enabling 2-Factor Authentication
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=EF Report Portal

# Comma-separated list of email recipients for monthly reminders
REMINDER_RECIPIENTS=team@efae.com,manager@efae.com

# "From" address for reminder emails
REMINDER_FROM='EF Report Portal <noreply@your-domain.com>'

# ──────────────────────────────────────────────
# Cron Job Security
# ──────────────────────────────────────────────
# Shared secret validated by ALL cron route endpoints via
# the Authorization: Bearer <CRON_SECRET> header.
# Vercel injects this automatically for scheduled cron runs.
# Generate a strong value: openssl rand -hex 32
CRON_SECRET=your-cron-secret

# ──────────────────────────────────────────────
# Automated Alert Email Recipients
# ──────────────────────────────────────────────
# Public URL of this deployment — used as the CTA button link in alert emails.
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Email address of the Contract Administration Department Head.
# CC'd on every automated bond expiry and EOT deadline alert email.
CONTRACT_ADMIN_EMAIL=contract.admin@efae.com

# ──────────────────────────────────────────────
# Ollama — AI Spreadsheet Assistant (local)
# ──────────────────────────────────────────────
# Requires Ollama running locally: https://ollama.com
# Pull the model: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ──────────────────────────────────────────────
# Google Gemini — Report text correction
# ──────────────────────────────────────────────
# API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the model (default: gemini-2.5-flash)
# GEMINI_MODEL=gemini-3.5-flash

# ──────────────────────────────────────────────
# Biometric Fingerprint Sync
# ──────────────────────────────────────────────
# Shared secret validated by the attendance-sync gateway route.
# Must match the INTERNAL_SYNC_TOKEN set in scripts/.env on the office server.
# Generate a strong random value: openssl rand -hex 32
INTERNAL_SYNC_TOKEN=your-strong-random-sync-token

# IP address of the ZKTeco fingerprint device on the office LAN.
# Used only by the local Python daemon (scripts/biometric_sync.py), not the web server.
BIOMETRIC_MACHINE_IP=192.168.1.100

# TCP port of the ZKTeco device (default 4370 — change only if your device differs).
BIOMETRIC_MACHINE_PORT=4370

# Device admin password (integer). Leave as 0 if your device has no password set.
BIOMETRIC_MACHINE_PASSWORD=0

# Full public URL of the Next.js attendance-sync route, used by the Python daemon.
# e.g. https://efae.vercel.app/api/registrar/attendance-sync
SYNC_GATEWAY_URL=https://your-app.vercel.app/api/registrar/attendance-sync

# IANA timezone for bucketing punch timestamps into calendar dates.
SYNC_TIMEZONE=Africa/Addis_Ababa

# Number of past days to pull from device memory on each sync run (default 2).
SYNC_LOOKBACK_DAYS=2

